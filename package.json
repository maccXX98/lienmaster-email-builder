{
  "name": "lienmaster-email-builder",
  "version": "1.3.0",
  "description": "A powerful and customizable email template builder React component library with visual editing, internationalization, and image upload support",
  "keywords": [
    "email",
    "email-builder",
    "email-template",
    "react",
    "react-component",
    "visual-editor",
    "template-editor"
